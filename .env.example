# Environment Variables

# Supabase Configuration (for database)
# Get these from https://supabase.com
# 1. Create account and project
# 2. Go to Settings > API to find these keys

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Razorpay Configuration
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Admin Portal Password (change this in production!)
ADMIN_PASSWORD=chai123

# Optional: Email Service (for real email notifications)
# SENDGRID_API_KEY=your_sendgrid_key
# RESEND_API_KEY=your_resend_key
# MAILGUN_API_KEY=your_mailgun_key
